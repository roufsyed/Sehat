<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with green and red colors. -->
    <style name="Theme.Saht" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!--Text Color-->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/light_grey</item>

        <!-- Primary brand color (Green). -->
        <item name="colorPrimary">@color/green_500</item>
        <item name="colorPrimaryVariant">@color/green_700</item>

        <!-- Secondary brand color (Red). -->
        <item name="colorSecondary">@color/red_500</item>
        <item name="colorSecondaryVariant">@color/red_700</item>

        <!-- Dark mode: deep background so cards (colorSurface) stand out -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Hardcoded so DynamicColors cannot override the status/nav bar -->
        <item name="android:statusBarColor">@color/green_700</item>
        <item name="android:navigationBarColor">@color/green_700</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>

    <!-- Custom: user-defined colors, overridden programmatically -->
    <style name="Theme.Saht.Custom" parent="Theme.Saht" />

    <style name="bottomSheetAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>


    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

</resources>
