<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom theme for DatePickerDialog -->
    <style name="CustomDatePickerStyle" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorAccent">?attr/colorPrimary</item>
    </style>


    <style name="CustomDialogTheme" parent="Theme.AppCompat.Dialog">
        <!-- Dialog Background -->
        <item name="android:background">@color/light_grey</item>
        <!-- Minimum Width and Height -->
        <item name="android:windowMinWidthMajor">100%</item>
        <item name="android:windowMinWidthMinor">100%</item>
        <!-- Center the dialog -->
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="RoundedCornersShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

</resources>
