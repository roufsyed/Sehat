<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with green and red colors. -->
    <style name="Theme.Saht" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!--Text Color-->
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorOnSecondary">@color/dark_grey</item>

        <!-- Primary brand color (Green). -->
        <item name="colorPrimary">@color/green_500</item>
        <item name="colorPrimaryVariant">@color/green_700</item>

        <!-- Secondary brand color (Red). -->
        <item name="colorSecondary">@color/red_500</item>
        <item name="colorSecondaryVariant">@color/red_700</item>

        <!-- Off-white background so white cards have contrast -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Hardcoded so DynamicColors cannot override the status/nav bar -->
        <item name="android:statusBarColor">@color/green_700</item>
        <item name="android:navigationBarColor">@color/green_700</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Customize any additional theme properties below. -->
    </style>

    <!-- Ocean: blue primary, orange accent -->
    <style name="Theme.Saht.Ocean" parent="Theme.Saht">
        <item name="colorPrimary">@color/blue_500</item>
        <item name="colorPrimaryVariant">@color/blue_700</item>
        <item name="colorSecondary">@color/orange_500</item>
        <item name="colorSecondaryVariant">@color/orange_500</item>
        <item name="android:statusBarColor">@color/blue_700</item>
        <item name="android:navigationBarColor">@color/blue_700</item>
    </style>

    <!-- Sunset: deep orange primary, violet accent -->
    <style name="Theme.Saht.Sunset" parent="Theme.Saht">
        <item name="colorPrimary">@color/deep_orange_500</item>
        <item name="colorPrimaryVariant">@color/deep_orange_700</item>
        <item name="colorSecondary">@color/violet_500</item>
        <item name="colorSecondaryVariant">@color/violet_700</item>
        <item name="android:statusBarColor">@color/deep_orange_700</item>
        <item name="android:navigationBarColor">@color/deep_orange_700</item>
    </style>

    <!-- Berry: violet primary, cyan accent -->
    <style name="Theme.Saht.Berry" parent="Theme.Saht">
        <item name="colorPrimary">@color/violet_500</item>
        <item name="colorPrimaryVariant">@color/violet_700</item>
        <item name="colorSecondary">@color/cyan_500</item>
        <item name="colorSecondaryVariant">@color/cyan_500</item>
        <item name="android:statusBarColor">@color/violet_700</item>
        <item name="android:navigationBarColor">@color/violet_700</item>
    </style>

    <style name="bottomSheetAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

    <style name="DialogThemeSize" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowMinWidthMajor">100%</item>
        <item name="android:windowMinWidthMinor">100%</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>
</resources>
