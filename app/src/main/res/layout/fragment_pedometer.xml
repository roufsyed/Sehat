<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".pedometer.view.PedometerFragment">

    <LinearLayout
        android:id="@+id/ll_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_button_cornered_solid_red"
        android:backgroundTint="?attr/colorSurface"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp">
        <ImageButton
            android:id="@+id/iv_history"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_history_24"
            android:background="@android:color/transparent"
            android:contentDescription="View step history" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_pedometer"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_circular"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="200dp">

        <TextView
            android:id="@+id/tv_stepsTaken"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:gravity="center"
            android:text="@string/initial_count"
            android:textSize="50sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_goalSteps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/step_goal"
            android:textSize="16sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_stepsTaken"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_calories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/calories"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_distance"
        app:layout_constraintTop_toBottomOf="@id/container_pedometer" />

    <TextView
        android:id="@+id/tv_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/distance"
        app:layout_constraintStart_toEndOf="@id/tv_calories"
        app:layout_constraintEnd_toStartOf="@id/tv_duration"
        app:layout_constraintTop_toBottomOf="@id/container_pedometer" />

    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/duration"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_distance"
        app:layout_constraintTop_toBottomOf="@id/container_pedometer" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_startStop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="120dp"
        android:minHeight="50dp"
        app:cornerRadius="20dp"
        android:text="@string/start"
        android:textColor="@color/white"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_distance"
        app:layout_constraintStart_toStartOf="@id/container_pedometer"
        app:layout_constraintEnd_toStartOf="@+id/btn_reset"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_reset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="120dp"
        android:minHeight="50dp"
        android:background="@drawable/bg_button_hollow_primary_border"
        android:text="@string/reset"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_distance"
        app:layout_constraintEnd_toEndOf="@id/container_pedometer"
        app:layout_constraintStart_toEndOf="@+id/btn_startStop"
        />

    <TextView
        android:id="@+id/tv_bmi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_hollow_primary_border"
        app:backgroundTint="@color/dark_grey"
        android:paddingHorizontal="16sp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="82dp"
        android:visibility="gone"
        android:text="@string/bmi_reading"/>

    <!-- Battery optimisation warning banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/banner_battery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="80dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="?attr/colorSecondaryContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_warning"
                android:importantForAccessibility="no"
                app:tint="?attr/colorOnSecondaryContainer" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Battery optimization may stop step counting in the background."
                android:textSize="13sp"
                android:textColor="?attr/colorOnSecondaryContainer" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_battery_allow"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allow"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp" />

            <ImageButton
                android:id="@+id/btn_battery_dismiss"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_add"
                android:rotation="45"
                android:background="@android:color/transparent"
                android:contentDescription="Dismiss"
                app:tint="?attr/colorOnSecondaryContainer" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>